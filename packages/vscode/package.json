{
  "name": "@naughtyagent/vscode",
  "displayName": "NaughtyAgent",
  "description": "AI 编程助手 - 类似 Claude Code 的 VS Code 插件",
  "version": "0.10.1",
  "publisher": "naughtyagent",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "assistant",
    "claude",
    "copilot",
    "agent"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "naughtyagent",
          "title": "NaughtyAgent",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "naughtyagent": [
        {
          "type": "webview",
          "id": "naughtyagent.chatView",
          "name": "Chat"
        },
        {
          "id": "naughtyagent.sessionsView",
          "name": "会话列表"
        }
      ]
    },
    "commands": [
      {
        "command": "naughtyagent.openChat",
        "title": "打开 AI 助手",
        "category": "NaughtyAgent",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "naughtyagent.askAboutSelection",
        "title": "询问选中代码",
        "category": "NaughtyAgent"
      },
      {
        "command": "naughtyagent.explainCode",
        "title": "解释代码",
        "category": "NaughtyAgent"
      },
      {
        "command": "naughtyagent.fixCode",
        "title": "修复代码",
        "category": "NaughtyAgent"
      },
      {
        "command": "naughtyagent.newChat",
        "title": "新建对话",
        "category": "NaughtyAgent",
        "icon": "$(add)"
      },
      {
        "command": "naughtyagent.clearChat",
        "title": "清空对话",
        "category": "NaughtyAgent",
        "icon": "$(clear-all)"
      },
      {
        "command": "naughtyagent.selectSession",
        "title": "选择会话",
        "category": "NaughtyAgent",
        "icon": "$(list-selection)"
      },
      {
        "command": "naughtyagent.newSession",
        "title": "新建会话",
        "category": "NaughtyAgent",
        "icon": "$(add)"
      },
      {
        "command": "naughtyagent.deleteSession",
        "title": "删除会话",
        "category": "NaughtyAgent",
        "icon": "$(trash)"
      },
      {
        "command": "naughtyagent.reconnect",
        "title": "重新连接",
        "category": "NaughtyAgent",
        "icon": "$(refresh)"
      },
      {
        "command": "naughtyagent.showDaemonStatus",
        "title": "显示 Daemon 状态",
        "category": "NaughtyAgent",
        "icon": "$(info)"
      },
      {
        "command": "naughtyagent.debugPing",
        "title": "调试发送链路",
        "category": "NaughtyAgent",
        "icon": "$(pulse)"
      },
      {
        "command": "naughtyagent.showLogs",
        "title": "显示日志",
        "category": "NaughtyAgent",
        "icon": "$(output)"
      },
      {
        "command": "naughtyagent.openChatInEditor",
        "title": "在编辑器中打开 Chat",
        "category": "NaughtyAgent",
        "icon": "$(window)"
      },
      {
        "command": "naughtyagent.switchToSession",
        "title": "切换到此会话",
        "category": "NaughtyAgent"
      },
      {
        "command": "naughtyagent.refreshSessions",
        "title": "刷新会话列表",
        "category": "NaughtyAgent",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "naughtyagent.askAboutSelection",
          "when": "editorHasSelection",
          "group": "naughtyagent@1"
        },
        {
          "command": "naughtyagent.explainCode",
          "when": "editorHasSelection",
          "group": "naughtyagent@2"
        },
        {
          "command": "naughtyagent.fixCode",
          "when": "editorHasSelection",
          "group": "naughtyagent@3"
        }
      ],
      "view/title": [
        {
          "command": "naughtyagent.newChat",
          "when": "view == naughtyagent.chatView",
          "group": "navigation"
        },
        {
          "command": "naughtyagent.openChatInEditor",
          "when": "view == naughtyagent.chatView",
          "group": "navigation"
        },
        {
          "command": "naughtyagent.clearChat",
          "when": "view == naughtyagent.chatView",
          "group": "navigation"
        },
        {
          "command": "naughtyagent.newSession",
          "when": "view == naughtyagent.sessionsView",
          "group": "navigation"
        },
        {
          "command": "naughtyagent.refreshSessions",
          "when": "view == naughtyagent.sessionsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "naughtyagent.deleteSession",
          "when": "view == naughtyagent.sessionsView && viewItem == session",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "naughtyagent.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "naughtyagent.askAboutSelection",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e",
        "when": "editorHasSelection"
      }
    ],
    "configuration": {
      "title": "NaughtyAgent",
      "properties": {
        "naughtyagent.serverUrl": {
          "type": "string",
          "default": "",
          "description": "Agent Daemon 服务地址（留空使用默认 127.0.0.1:31415）"
        },
        "naughtyagent.defaultAgent": {
          "type": "string",
          "enum": [
            "build",
            "plan",
            "explore"
          ],
          "default": "build",
          "description": "默认 Agent 类型"
        },
        "naughtyagent.autoConfirm.read": {
          "type": "boolean",
          "default": true,
          "description": "自动确认读取文件操作"
        },
        "naughtyagent.autoConfirm.glob": {
          "type": "boolean",
          "default": true,
          "description": "自动确认文件搜索操作"
        },
        "naughtyagent.autoConfirm.grep": {
          "type": "boolean",
          "default": true,
          "description": "自动确认内容搜索操作"
        },
        "naughtyagent.autoConfirm.write": {
          "type": "boolean",
          "default": false,
          "description": "自动确认写入文件操作"
        },
        "naughtyagent.autoConfirm.edit": {
          "type": "boolean",
          "default": false,
          "description": "自动确认编辑文件操作"
        },
        "naughtyagent.autoConfirm.bash": {
          "type": "boolean",
          "default": false,
          "description": "自动确认执行命令操作"
        },
        "naughtyagent.includeCurrentFile": {
          "type": "boolean",
          "default": true,
          "description": "自动包含当前文件作为上下文"
        },
        "naughtyagent.includeSelection": {
          "type": "boolean",
          "default": true,
          "description": "自动包含选中代码作为上下文"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.10",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
